{
  "name": "pricecloud-api",
  "version": "1.0.0",
  "description": "",
  "author": "sebastianaf",
  "private": true,
  "license": "GNU GPLv3",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build && npm run copyfiles",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "copyfiles": "copyfiles -V -u 1 \"./src/**/*.svg\" \"./src/**/*.md\" \"dist\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node -r tsconfig-paths/register src/seed/main.ts",
    "migrations:generate": "ts-node ./src/database/migrate.ts",
    "migrations:run": "npm run typeorm -- migration:run -d \"./src/database/datasource.ts\"",
    "migrations:show": "npm run typeorm -- migration:show -d \"./src/database/datasource.ts\"",
    "migrations:drop": "npm run typeorm -- migration:drop -d \"./src/database/datasource.ts\"",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "2.1.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "11.0.0",
    "@nestjs/websockets": "11.1.14",
    "axios": "^1.13.5",
    "bcrypt": "5.1.1",
    "change-case": "5.4.4",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "cookie-parser": "^1.4.7",
    "copyfiles": "2.4.1",
    "cors": "2.8.6",
    "express-useragent": "1.0.15",
    "joi": "17.13.3",
    "jsonwebtoken": "9.0.3",
    "moment": "2.30.1",
    "nodemailer": "^6.10.1",
    "passport": "0.7.0",
    "passport-custom": "1.1.1",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.18.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io-client": "4.8.3",
    "tsconfig-paths": "4.2.0",
    "typeorm": "0.3.28",
    "typeorm-naming-strategies": "4.1.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.14",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20.19.33",
    "@types/nodemailer": "6.4.22",
    "@types/passport-jwt": "3.0.13",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "2.0.16",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "29.7.0",
    "prettier": "3.8.1",
    "source-map-support": "0.5.21",
    "supertest": "6.3.4",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
