{
  "name": "cloud-pricing-api",
  "version": "0.3.18",
  "description": "Cloud Pricing API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "postbuild": "copyfiles -u 1 src/views/**/** dist && copyfiles -u 1 src/public/**/** dist",
    "start": "node dist/server.js",
    "db:setup": "node dist/cmd/dbSetup.js",
    "data:scrape": "node dist/cmd/dataScrape.js",
    "data:dump": "node dist/cmd/dataDump.js",
    "data:download": "node dist/cmd/dataDownload.js",
    "data:load": "node dist/cmd/dataLoad.js",
    "data:status": "node dist/cmd/dataStatus.js",
    "job:init": "npm run db:setup && npm run job:update",
    "job:update": "node dist/cmd/jobUpdate.js",
    "db:setup:dev": "ts-node src/cmd/dbSetup.ts",
    "data:scrape:dev": "ts-node src/cmd/dataScrape.ts",
    "data:dump:dev": "ts-node src/cmd/dataDump.ts",
    "data:download:dev": "ts-node src/cmd/dataDownload.ts",
    "data:load:dev": "ts-node src/cmd/dataLoad.ts",
    "data:status:dev": "ts-node src/cmd/dataStatus.ts",
    "job:init:dev": "npm run db:setup:dev && npm run job:update:dev",
    "job:update:dev": "ts-node src/cmd/jobUpdate.ts",
    "lint": "eslint --ext .ts,.js --ignore-path .gitignore .",
    "format": "prettier --write 'src/**/*.{js,ts}'"
  },
  "author": "Infracost",
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "https://raw.githubusercontent.com/infracost/cloud-pricing-api/master/LICENSE"
    }
  ],
  "dependencies": {
    "@graphql-tools/schema": "^9.0.19",
    "@graphql-tools/utils": "^9.2.1",
    "@types/winston": "^2.4.4",
    "apollo-server-core": "^3.13.0",
    "apollo-server-express": "^3.13.0",
    "apollo-server-plugin-base": "^3.7.2",
    "async-mutex": "^0.5.0",
    "axios": "^1.13.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "glob": "^8.1.0",
    "googleapis": "^110.0.0",
    "graphql": "^16.12.0",
    "lodash": "^4.17.23",
    "mingo": "^6.7.2",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "pg": "^8.18.0",
    "pg-copy-streams": "^6.0.6",
    "pg-format": "^1.0.4",
    "pino": "8.21.0",
    "pino-http": "^8.6.1",
    "pino-pretty": "^9.4.1",
    "prettier": "^2.8.8",
    "socket.io": "^4.8.3",
    "tmp": "^0.2.5",
    "winston": "^3.19.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@types/glob": "^8.1.0",
    "@types/lodash": "^4.17.23",
    "@types/node": "^20.19.33",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.16.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/pg-format": "^1.0.5",
    "@types/pino-http": "^5.8.4",
    "@types/prettier": "^2.7.3",
    "@types/tmp": "^0.2.6",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infracost/cloud-pricing-api.git"
  }
}
