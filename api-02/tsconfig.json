{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "lib": ["esnext", "es2018", "dom"],
    "esModuleInterop": true,
    "declaration": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*"]
}
